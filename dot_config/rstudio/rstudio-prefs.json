{
  "initial_working_directory": "~",
  "editor_keybindings": "vim",
  "posix_terminal_shell": "custom",
  "custom_shell_command": "/opt/homebrew/bin/fish",
  "jobs_tab_visibility": "shown",
  "rmd_viewer_type": "pane",
  "spelling_dictionary_language": "en_AU",
  "num_spaces_for_tab": 4,
  "insert_native_pipe_operator": true,
  "panes": {
    "quadrants": [
      "Source",
      "Console",
      "TabSet1",
      "TabSet2"
    ],
    "tabSet1": [
      "Environment",
      "History",
      "Connections",
      "Build",
      "VCS",
      "Tutorial",
      "Presentation"
    ],
    "tabSet2": [
      "Files",
      "Plots",
      "Packages"
    ],
    "hiddenTabSet": [
      "Chat"
    ],
    "console_left_on_top": false,
    "console_right_on_top": true,
    "additional_source_columns": 0,
    "sidebar": [
      "Help",
      "Viewer",
      "Presentations"
    ],
    "sidebar_visible": true,
    "sidebar_location": "left"
  },
  "editor_theme": "Chrome",
  "default_project_location": "~/R-Projekte"
}
