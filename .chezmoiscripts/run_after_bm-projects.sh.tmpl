#!/usr/bin/env bash
set -euo pipefail

command -v bm >/dev/null 2>&1 || {
    echo "basic-memory (bm) is required"
    exit 1
}

home='{{ .chezmoi.homeDir }}'

main_path="$home/OpenCloud/Zettlr/bm"
erasmus_path="$home/Arbeit/Erasmus/Notes"

current_json="$(bm project list --local --json)"

stale_main_present() {
    grep -Eq '"local_path"[[:space:]]*:[[:space:]]*"~/basic-memory"' <<<"$current_json"
}

project_exists() {
    grep -Eq "\"name\"[[:space:]]*:[[:space:]]*\"$1\"" <<<"$current_json"
}

if stale_main_present; then
    echo "Stale 'main' project detected (local_path ~/basic-memory)"

    if project_exists erasmus; then
        echo "Re-registering 'erasmus' as default to free up 'main'"
        bm project remove erasmus --local
        bm project add erasmus "$erasmus_path" --default --local
    else
        echo "Adding 'erasmus' as default to free up 'main'"
        bm project add erasmus "$erasmus_path" --default --local
    fi

    echo "Removing stale 'main' project"
    bm project remove main --local

    current_json="$(bm project list --local --json)"
fi

if project_exists main; then
    echo "Project 'main' already present, skipping"
else
    echo "Adding project 'main' -> $main_path"
    bm project add main "$main_path" --default --local
fi

current_json="$(bm project list --local --json)"

if project_exists erasmus; then
    echo "Project 'erasmus' already present, skipping"
else
    echo "Adding project 'erasmus' -> $erasmus_path"
    bm project add erasmus "$erasmus_path" --local
fi
